{
  "name": "cms-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "CMS 移动端配置项目 Monorepo",
  "scripts": {
    "dev": "turbo run dev",
    "dev:cms": "pnpm --filter @cms/cms dev",
    "dev:crs": "pnpm --filter @cms/crs dev",
    "build": "turbo run build",
    "build:cms": "pnpm --filter @cms/cms build",
    "build:crs": "pnpm --filter @cms/crs build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{js,ts,vue,json}\"",
    "typecheck": "turbo run typecheck",
    "check:ui-governance": "node scripts/check-ui-governance.mjs",
    "gen:material": "node scripts/generate-material.mjs",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "prepare": "husky install",
    "ci:lint": "pnpm lint",
    "ci:typecheck": "pnpm typecheck",
    "ci:test": "turbo run test -- --run",
    "ci:build": "pnpm build",
    "ci:quality": "pnpm run ci:lint && pnpm run ci:typecheck && pnpm run ci:test && pnpm run ci:build",
    "security:audit": "pnpm audit --recursive --audit-level high",
    "security:secrets": "pnpm dlx gitleaks detect --source . --no-banner --redact --config .gitleaks.toml",
    "security:sast": "pnpm dlx semgrep scan --config .semgrep/rules.yml --error --exclude node_modules --exclude dist .",
    "security:scan": "pnpm run security:audit && pnpm run security:secrets && pnpm run security:sast",
    "ci:all": "pnpm run ci:quality && pnpm run security:scan"
  },
  "devDependencies": {
    "@cms/eslint-config": "workspace:*",
    "@cms/prettier-config": "workspace:*",
    "@vitest/coverage-v8": "3",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "rimraf": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  }
}
